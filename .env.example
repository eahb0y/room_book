# Backend base URL
# Local example: http://localhost:3000
# Production example: https://api.example.com
VITE_API_BASE_URL=http://localhost:3000

# Optional manual override: dev | prod
# VITE_APP_ENV=dev

# Telegram bot username without @
# Example: tezbron_booking_bot
# VITE_TELEGRAM_BOT_USERNAME=tezbron_booking_bot

# Public app URL for canonical tags / Open Graph / sitemap generation
# Example: https://app.example.com
# VITE_SITE_URL=https://app.example.com
