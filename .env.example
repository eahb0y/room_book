# Supabase development instance (used when running locally)
VITE_SUPABASE_DEV_URL=https://your-dev-project-ref.supabase.co
VITE_SUPABASE_DEV_PUBLISHABLE_KEY=sb_publishable_dev_xxx

# Supabase production instance (used on published production app)
VITE_SUPABASE_PROD_URL=https://your-prod-project-ref.supabase.co
VITE_SUPABASE_PROD_PUBLISHABLE_KEY=sb_publishable_prod_xxx

# Optional shared instance variables (legacy)
# Use these if dev and prod point to the same Supabase project.
# VITE_SUPABASE_URL=https://your-shared-project-ref.supabase.co
# VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_shared_xxx

# Optional manual override: dev | prod
# VITE_APP_ENV=dev

# Telegram bot username without @
# Example: tezbron_booking_bot
# VITE_TELEGRAM_BOT_USERNAME=tezbron_booking_bot

# Telegram notification worker
# APP_ENV=dev
# SUPABASE_SERVICE_ROLE_KEY=sb_service_role_xxx
# TELEGRAM_BOT_TOKEN=123456:ABCDEF
# TELEGRAM_WORKER_INTERVAL_MS=5000
# TELEGRAM_WORKER_BATCH_SIZE=20

# Public app URL for canonical tags / Open Graph / sitemap generation
# Example: https://app.example.com
# VITE_SITE_URL=https://app.example.com
